<div class="fwmb-map-container">

    <div class="fwmb-edit-toolbar fwmb-hidden">
        <div class="fwmb-brush-settings">
            <div class="fwmb-brush-setting">
                <label>{{localize "FILRODENSWMB.UI.BrushSize"}}</label>
                <div class="fwmb-slider-group">
                    <input type="range" name="brushSize" value="20" min="5" max="100" step="1" oninput="this.nextElementSibling.value = this.value" />
                    <output>20</output>
                </div>
            </div>

            <div class="fwmb-brush-setting">
                <label>{{localize "FILRODENSWMB.UI.BrushStrength"}}</label>
                <div class="fwmb-slider-group">
                    <input type="range" name="brushStrength" value="0.05" min="0.01" max="0.5" step="0.01" oninput="this.nextElementSibling.value = this.value" />
                    <output>0.05</output>
                </div>
            </div>

            <div class="fwmb-brush-setting">
                <label>{{localize "FILRODENSWMB.UI.BrushFeather"}}</label>
                <div class="fwmb-slider-group">
                    <input type="range" name="brushFeather" value="0.5" min="0" max="1" step="0.1" oninput="this.nextElementSibling.value = this.value" />
                    <output>0.5</output>
                </div>
            </div>
        </div>

        <div class="fwmb-divider-vertical"></div>

        <div class="fwmb-brush-tools">
            <button type="button" data-action="setBrushTool" data-tool="raise" class="active" data-tooltip="{{localize 'FILRODENSWMB.UI.ToolRaise'}}">
                <i class="fwmb-icon edit_arrow_up"></i>
            </button>
            <button type="button" data-action="setBrushTool" data-tool="lower" data-tooltip="{{localize 'FILRODENSWMB.UI.ToolLower'}}">
                <i class="fwmb-icon edit_arrow_down"></i>
            </button>
            <button type="button" data-action="setBrushTool" data-tool="smooth" data-tooltip="{{localize 'FILRODENSWMB.UI.ToolSmooth'}}">
                <i class="fwmb-icon landscape"></i>
            </button>
        </div>

        <div class="fwmb-divider-vertical"></div>

        <div class="fwmb-brush-history">
            <button type="button" data-action="undoBrush" data-tooltip="{{localize 'FILRODENSWMB.UI.Undo'}}">
                <i class="fwmb-icon undo"></i>
            </button>
        </div>
    </div>

    <div class="fwmb-map-preview"></div>

    <div class="fwmb-map-hint">{{localize "FILRODENSWMB.UI.CanvasHint"}}</div>

    <div class="fwmb-zoom-controls">
        <button type="button" data-action="toggleGrid" data-tooltip="{{localize 'FILRODENSWMB.UI.ToggleGrid'}}">
            <i class="fwmb-icon grid-on"></i>
        </button>
        <div class="fwmb-divider-vertical"></div>
        <button type="button" data-action="zoomOut" data-tooltip="{{localize 'FILRODENSWMB.UI.ZoomOut'}}">
            <i class="fwmb-icon zoom-out"></i>
        </button>
        <button type="button" data-action="resetZoom" data-tooltip="{{localize 'FILRODENSWMB.UI.ResetView'}}">
            <i class="fwmb-icon center-focus"></i>
        </button>
        <button type="button" data-action="zoomIn" data-tooltip="{{localize 'FILRODENSWMB.UI.ZoomIn'}}">
            <i class="fwmb-icon zoom-in"></i>
        </button>
    </div>
</div>