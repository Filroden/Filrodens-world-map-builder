<form>
    <div class="form-group stacked">
        <label>{{localize "FILRODENSWMB.UI.LabelText"}}</label>
        <input type="text" name="labelName" value="{{label.name}}" required />
    </div>

    <div class="form-group">
        <label>{{localize "FILRODENSWMB.UI.FontFamily"}}</label>
        <select name="labelFontFamily">
            {{#each fonts}}
                <option value="{{this}}" {{#if (eq ../label.fontFamily this)}}selected{{/if}}>{{this}}</option>
            {{/each}}
        </select>
    </div>

    <div class="form-group">
        <label>{{localize "FILRODENSWMB.UI.FontSize"}}</label>
        <div class="fwmb-slider-group">
            <input type="range" name="labelFontSize" value="{{label.fontSize}}" min="0.2" max="5.0" step="0.1" oninput="this.nextElementSibling.value = this.value" />
            <output>{{label.fontSize}}</output>
        </div>
    </div>

    <div class="form-group">
        <label>{{localize "FILRODENSWMB.UI.FontColor"}}</label>
        <div style="display: flex; flex-direction: column; gap: var(--fwmb-space-s);">
            <div class="fwmb-color-row">
                {{#each palette}}
                    <button type="button" class="fwmb-swatch fwmb-preset-swatch fwmb-swatch-lg" style="background-color: {{this}};" data-color="{{this}}" title="{{this}}"></button>
                {{/each}}
            </div>
            <input type="color" class="fwmb-swatch fwmb-wide" name="labelFillColor" value="{{label.fillColor}}" />
        </div>
    </div>
</form>