<div class="fwmb-dialog-content">

    <div class="form-group stacked">
        <label>{{localize "FILRODENSWMB.UI.Name"}}</label>
        <input type="text" name="pinName" value="{{pin.name}}" />
    </div>

    <div class="form-group stacked">
        <label>{{localize "FILRODENSWMB.UI.Description"}}</label>
        <textarea class="fwmb-scrollable stable" name="pinDesc" rows="4">{{pin.description}}</textarea>
    </div>

    <div class="form-group">
        <label>{{localize "FILRODENSWMB.UI.SelectIcon"}}</label>
        <select name="pinIcon">
            {{#each icons}}
                <option value="{{this.key}}" {{#if this.selected}}selected{{/if}}>{{this.localized}}</option>
            {{/each}}
        </select>
    </div>

    <div class="form-group">
        <label>{{localize "FILRODENSWMB.UI.IconScale"}}</label>
        <div class="fwmb-slider-group">
            <input type="range" name="pinScale" value="{{pin.scale}}" min="0.2" max="4" step="0.1" />
            <output>{{pin.scale}}</output>
        </div>
    </div>

</div>