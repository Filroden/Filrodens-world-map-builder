<div class="fwmb-tool-content fwmb-scrollable">

    <fieldset class="fwmb-fieldset fwmb-flex-1" style="flex: 1; min-height: 0;">
        <legend>{{localize "FILRODENSWMB.UI.AutoLabels"}}</legend>
        <div class="fwmb-list-container fwmb-scrollable stable" style="margin-top: var(--fwmb-space-m);">
            
            {{#each autoLabels}}
            <div class="fwmb-list-item" data-id="{{this.id}}" data-type="{{this.dataType}}" {{#if this.layerId}}data-layer-id="{{this.layerId}}"{{/if}}>
                <button type="button" class="fwmb-btn small" data-action="toggleVisibility" data-target="label" data-tooltip="{{localize 'FILRODENSWMB.UI.ToggleVisibility'}}">
                    <i class="fwmb-icon {{#if (eq this.displayVisibility 'none')}}visibility-off{{else if (eq this.displayVisibility 'gm')}}security{{else}}visibility{{/if}}"></i>
                </button>
                <span class="fwmb-name fwmb-flex-1 fwmb-truncate">{{this.name}}</span>
                <button type="button" class="fwmb-btn small" data-action="zoomToFeature" data-tooltip="{{localize 'FILRODENSWMB.UI.ZoomTo'}}">
                    <i class="fwmb-icon center-focus"></i>
                </button>
                <button type="button" class="fwmb-btn small" data-action="editLabel" data-tooltip="{{localize 'FILRODENSWMB.UI.Edit'}}">
                    <i class="fwmb-icon edit"></i>
                </button>
            </div>
            {{else}}
            <div class="fwmb-empty-state">{{localize "FILRODENSWMB.UI.NoLabels"}}</div>
            {{/each}}

        </div>
    </fieldset>

    <fieldset class="fwmb-fieldset fwmb-flex-1" style="flex: 1; min-height: 0;">
        <legend>{{localize "FILRODENSWMB.UI.CustomLabels"}}</legend>

        <div class="fwmb-list-container fwmb-scrollable stable" style="margin-top: var(--fwmb-space-m);">
            {{#each mapLabels}}
            <div class="fwmb-list-item" data-id="{{this.id}}" data-type="custom">
                <button type="button" class="fwmb-btn small" data-action="toggleVisibility" data-target="label" data-tooltip="{{localize 'FILRODENSWMB.UI.ToggleVisibility'}}">
                    <i class="fwmb-icon {{#if (eq this.visibility 'none')}}visibility-off{{else if (eq this.visibility 'gm')}}security{{else}}visibility{{/if}}"></i>
                </button>
                <span class="fwmb-name fwmb-flex-1 fwmb-truncate">{{this.name}}</span>
                <button type="button" class="fwmb-btn small" data-action="zoomToFeature" data-tooltip="{{localize 'FILRODENSWMB.UI.ZoomTo'}}">
                    <i class="fwmb-icon center-focus"></i>
                </button>
                <button type="button" class="fwmb-btn small" data-action="editLabel" data-tooltip="{{localize 'FILRODENSWMB.UI.Edit'}}">
                    <i class="fwmb-icon edit"></i>
                </button>
                <button type="button" class="fwmb-btn small muted danger" data-action="deleteLabel" data-tooltip="{{localize 'FILRODENSWMB.UI.Delete'}}">
                    <i class="fwmb-icon delete"></i>
                </button>
            </div>
            {{else}}
            <div class="fwmb-empty-state">{{localize "FILRODENSWMB.UI.NoLabels"}}</div>
            {{/each}}
        </div>
    </fieldset>
    
    <div class="fwmb-flex-1"></div>
    <div class="fwmb-divider"></div>
    
    <button type="button" class="fwmb-btn primary" data-action="toggleEditMode">
        <i class="fwmb-icon brush"></i>
        {{localize "FILRODENSWMB.UI.EditLabel"}}
    </button>
</div>