<div class="fwmb-tool-content">
    {{#*inline "mapNode"}}
        <div class="fwmb-accordion-group">
            <div class="fwmb-map-card" data-id="{{this.id}}">
                <div class="fwmb-map-card-info">
                    {{this.name}}
                </div>

                <div class="fwmb-map-card-actions">
                    <button type="button" data-action="manageMap" data-action-type="load" data-tooltip="{{localize 'FILRODENSWMB.UI.Load'}}">
                        <i class="fwmb-icon file-open"></i>
                    </button>

                    <div class="fwmb-dropdown" tabindex="0">
                        <button type="button" data-tooltip="Options">
                            <i class="fwmb-icon more-vert"></i>
                        </button>

                        <div class="fwmb-dropdown-menu">
                            <button type="button" data-action="manageMap" data-action-type="rename">
                                <i class="fwmb-icon edit"></i>
                                {{localize "FILRODENSWMB.UI.Rename"}}
                            </button>
                            <button type="button" data-action="manageMap" data-action-type="duplicate">
                                <i class="fwmb-icon content-copy"></i>
                                {{localize "FILRODENSWMB.UI.Duplicate"}}
                            </button>
                            <button type="button" data-action="manageMap" data-action-type="export">
                                <i class="fwmb-icon file-export"></i>
                                {{localize "FILRODENSWMB.UI.Export"}}
                            </button>
                            <button type="button" data-action="manageMap" data-action-type="delete" class="fwmb-danger" style="border-block-start: 1px solid var(--fwmb-border-subtle);">
                                <i class="fwmb-icon delete"></i>
                                {{localize "FILRODENSWMB.UI.Delete"}}
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            {{#if this.children.length}}
                <div class="fwmb-accordion-content" style="margin-left: 12px; padding-left: 8px; border-left: 2px solid var(--fwmb-border-subtle);">
                    {{#each this.children}}
                        {{> mapNode this}}
                    {{/each}}
                </div>
            {{/if}}
        </div>
    {{/inline}}

    <div class="fwmb-panel-header">
        <h3>{{localize "FILRODENSWMB.UI.SavedMaps"}}</h3>
    </div>

    <div class="fwmb-map-list fwmb-scrollable stable">
        {{#each savedMaps}}
            {{> mapNode this}}
        {{else}}
            <div class="fwmb-empty-state">
                <p>{{localize "FILRODENSWMB.UI.NoSavedMaps"}}</p>
            </div>
        {{/each}}
    </div>

    <div class="fwmb-divider"></div>

    <button type="button" data-action="importMapJson" style="width: auto; padding: 0 8px;">
        <i class="fwmb-icon upload-file"></i>
        {{localize "FILRODENSWMB.UI.ImportJSON"}}
    </button>
</div>