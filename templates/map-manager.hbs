<div class="fhc-map-manager-content">

    <fieldset class="fhc-fieldset">
        <legend>{{localize "FILRODENSHEX.UI.SaveMap"}}</legend>
        <p class="hint">{{localize "FILRODENSHEX.UI.SaveMapHint"}}</p>

        <div class="form-group">
            <label for="fhc-save-name">{{localize "FILRODENSHEX.UI.MapName"}}</label>
            <div class="fhc-flex-row">
                <input type="text" id="fhc-save-name" class="fhc-flex-1" placeholder="e.g. The Sword Coast" />
                <button type="button" class="fhc-btn primary" data-action="saveMap" title="{{localize 'FILRODENSHEX.Actions.Save'}}">
                    <i class="fhc-icon file_save"></i>
                </button>
            </div>
        </div>
    </fieldset>

    <fieldset class="fhc-fieldset">
        <legend>{{localize "FILRODENSHEX.UI.LoadMap"}}</legend>

        {{#if maps.length}}
            <div class="fhc-map-list fhc-scrollable">
                {{#each maps}}
                    <div class="fhc-map-item">
                        <span class="fhc-map-name">{{this.name}}</span>
                        <div class="fhc-map-actions">
                            <button type="button" class="fhc-btn primary" data-action="loadMap" data-id="{{this.id}}" title="{{localize 'FILRODENSHEX.Actions.Load'}}">
                                <i class="fhc-icon file_open"></i>
                            </button>
                            <button type="button" class="fhc-btn danger" data-action="deleteMap" data-id="{{this.id}}" title="{{localize 'FILRODENSHEX.Actions.Delete'}}">
                                <i class="fhc-icon delete"></i>
                            </button>
                        </div>
                    </div>
                {{/each}}
            </div>
        {{else}}
            <div class="fhc-empty">
                <p>{{localize "FILRODENSHEX.UI.NoMapsSaved"}}</p>
            </div>
        {{/if}}
    </fieldset>

</div>