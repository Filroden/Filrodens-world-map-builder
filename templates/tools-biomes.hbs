<div class="fwmb-tool-content fwmb-scrollable">

    <fieldset class="fwmb-fieldset">
        <legend>{{localize "FILRODENSWMB.UI.ClimateSettings"}}</legend>

        <div class="form-group">
            <label>{{localize "FILRODENSWMB.UI.GlobalTemp"}}</label>
            <input type="range" name="globalTemp" value="{{config.DEFAULTS.GLOBAL_TEMP}}" min="0" max="1" step="0.01" />
        </div>

        <div class="form-group">
            <label>{{localize "FILRODENSWMB.UI.SeasonOffset"}}</label>
            <div class="fwmb-slider-group">
                <input type="range" name="seasonOffset" value="0" min="-1" max="1" step="0.05" />
            </div>
        </div>

        <div class="form-group stacked">
            <label>{{localize "FILRODENSWMB.UI.Latitude"}}</label>
            <div class="fwmb-flex-row">
                <div class="fwmb-flex-1 form-group">
                    <label class="hint">{{localize "FILRODENSWMB.UI.LatTop"}}</label>
                    <input type="number" name="latTop" value="{{config.DEFAULTS.LAT_TOP}}" min="-90" max="90" />
                </div>
                <div class="fwmb-flex-1 form-group">
                    <label class="hint">{{localize "FILRODENSWMB.UI.LatBottom"}}</label>
                    <input type="number" name="latBottom" value="{{config.DEFAULTS.LAT_BOTTOM}}" min="-90" max="90" />
                </div>
            </div>
        </div>
    </fieldset>

    <fieldset class="fwmb-fieldset">
        <legend>{{localize "FILRODENSWMB.UI.MoistureSettings"}}</legend>

        <div class="form-group">
            <label>{{localize "FILRODENSWMB.UI.GlobalMoisture"}}</label>
            <input type="range" name="globalMoisture" value="0.5" min="0" max="1" step="0.01" />
        </div>

        <div class="form-group">
            <label>{{localize "FILRODENSWMB.UI.MoistureScale"}}</label>
            <input type="range" name="noise.moisture.scale" value="500" min="100" max="2000" step="50" />
        </div>
    </fieldset>

    <fieldset class="fwmb-fieldset">
        <legend>{{localize "FILRODENSWMB.UI.BiomeLegend"}}</legend>
        <div class="fwmb-biome-legend">
            {{#each biomeLegend}}
                <div class="fwmb-biome-item">
                    <span class="fwmb-biome-swatch" style="background-color: {{this.color}};"></span>
                    <span>{{localize this.label}}</span>
                </div>
            {{/each}}
        </div>
    </fieldset>

    <div class="fwmb-flex-1"></div>
    <div class="fwmb-divider"></div>

    <button type="button" class="fwmb-btn primary" data-action="toggleEditMode">
        <i class="fwmb-icon brush"></i>
        {{localize "FILRODENSWMB.UI.EditBiome"}}
    </button>

</div>